# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# Flask secret key — change this to a random string in production
SECRET_KEY=change-me-to-a-random-string

# Exchange SMTP — use an app password, not your main account password
# MAIL_USERNAME is your full email address (e.g. you@yourdomain.com)
# Also requires: (1) Azure AD Security Defaults disabled, (2) Authenticated SMTP
# enabled per-mailbox in Microsoft 365 Admin Center → Users → Mail → Manage email apps
MAIL_SERVER=smtp.office365.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=david@dglc.com
MAIL_PASSWORD=your-exchange-app-password-here
MAIL_DEFAULT_SENDER=david@dglc.com
