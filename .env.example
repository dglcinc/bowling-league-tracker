# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# Flask secret key — change this to a random string in production
SECRET_KEY=change-me-to-a-random-string

# WeasyPrint PDF generation (Apple Silicon Mac) — see README step 1 for required symlinks
DYLD_LIBRARY_PATH=/opt/homebrew/lib

# Microsoft Graph API — used for sending email (replaces SMTP)
# Register an app in Azure AD, grant Mail.Send application permission, grant admin consent
GRAPH_TENANT_ID=your-directory-tenant-id-here
GRAPH_CLIENT_ID=your-application-client-id-here
GRAPH_CLIENT_SECRET=your-client-secret-value-here
GRAPH_SENDER_EMAIL=david@dglc.com

# Cloudflare Turnstile CAPTCHA (leave blank in dev to skip verification)
TURNSTILE_SITE_KEY=your-turnstile-site-key-here
TURNSTILE_SECRET_KEY=your-turnstile-secret-key-here

# WebAuthn / Passkeys
WEBAUTHN_RP_ID=yourdomain.com
WEBAUTHN_RP_NAME=League Tracker
WEBAUTHN_ORIGIN=https://yourdomain.com
REMEMBER_COOKIE_SECURE=true

# Web Push (VAPID) — generate once with py-vapid, never change after first subscriber
VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_PEM=your-vapid-private-pem-base64-here
VAPID_CLAIMS_EMAIL=you@yourdomain.com
