# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# Flask secret key — change this to a random string in production
SECRET_KEY=change-me-to-a-random-string

# WeasyPrint PDF generation (Apple Silicon Mac) — see README step 1 for required symlinks
DYLD_LIBRARY_PATH=/opt/homebrew/lib

# Microsoft Graph API — used for sending email (replaces SMTP)
# Register an app in Azure AD, grant Mail.Send application permission, grant admin consent
GRAPH_TENANT_ID=your-directory-tenant-id-here
GRAPH_CLIENT_ID=your-application-client-id-here
GRAPH_CLIENT_SECRET=your-client-secret-value-here
GRAPH_SENDER_EMAIL=david@dglc.com
